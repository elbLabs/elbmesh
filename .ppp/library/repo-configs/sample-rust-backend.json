{
  "schemaVersion": 1,
  "repoKey": "sample-rust-backend",
  "name": "Sample Rust Axum Backend",
  "description": "Example repo-specific PPP mapping for an Axum backend with layered DDD boundaries.",
  "root": ".",
  "tags": [
    { "tagId": "tag.language", "value": "rust" },
    { "tagId": "tag.framework", "value": "axum" },
    { "tagId": "tag.stack", "value": "rust-axum" }
  ],
  "dependencies": [
    {
      "ecosystem": "cargo",
      "packageName": "axum",
      "requirement": "^0.7",
      "resolvedVersion": "0.7.9",
      "resolvedVersions": ["0.7.9"],
      "scope": "dependencies",
      "features": ["json", "macros", "tokio"],
      "defaultFeatures": true,
      "optional": false,
      "dev": false,
      "build": false,
      "workspace": {
        "inherited": true,
        "member": true,
        "root": true,
        "packagePath": "crates/api"
      },
      "registry": "crates-io",
      "source": {
        "manifestPath": "Cargo.toml",
        "lockfilePath": "Cargo.lock",
        "packageManager": "cargo",
        "packageManagerVersion": "1.84.0",
        "provenance": "Declared in workspace dependencies and inherited by crates/api."
      }
    },
    {
      "ecosystem": "cargo",
      "packageName": "tokio",
      "requirement": "^1",
      "resolvedVersion": "1.42.0",
      "scope": "dependencies",
      "features": ["macros", "rt-multi-thread", "signal"],
      "defaultFeatures": true,
      "optional": false,
      "dev": false,
      "build": false,
      "workspace": {
        "inherited": true,
        "member": true,
        "root": true,
        "packagePath": "crates/api"
      },
      "registry": "crates-io",
      "source": {
        "manifestPath": "Cargo.toml",
        "lockfilePath": "Cargo.lock",
        "packageManager": "cargo",
        "packageManagerVersion": "1.84.0",
        "provenance": "Runtime used by Axum handlers and HTTP tests."
      }
    },
    {
      "ecosystem": "cargo",
      "packageName": "serde",
      "requirement": "^1",
      "resolvedVersion": "1.0.216",
      "scope": "dependencies",
      "features": ["derive"],
      "defaultFeatures": true,
      "optional": false,
      "dev": false,
      "build": false,
      "workspace": {
        "inherited": true,
        "member": true,
        "root": true,
        "packagePath": "crates/api"
      },
      "registry": "crates-io",
      "source": {
        "manifestPath": "Cargo.toml",
        "lockfilePath": "Cargo.lock",
        "packageManager": "cargo",
        "packageManagerVersion": "1.84.0",
        "provenance": "Transport DTO serialization dependency."
      }
    }
  ],
  "mappings": [
    {
      "id": "axum-http-handlers",
      "name": "Axum HTTP handlers",
      "description": "Handler, DTO, route, and HTTP error mapping files should use thin adapter guidance.",
      "paths": [
        "crates/api/src/http/**/*.rs",
        "crates/api/src/routes/**/*.rs",
        "crates/api/src/handlers/**/*.rs"
      ],
      "tags": [
        { "tagId": "tag.layer", "value": "http" },
        { "tagId": "tag.topic", "value": "api-endpoint" }
      ],
      "ppp": {
        "requiredSlugs": [
          "principle.explicit-boundaries",
          "pattern.http-use-case-adapter",
          "stack.rust-axum",
          "recipe.rust-axum-thin-handler",
          "recipe.rust-axum-error-mapping",
          "validation.rust-api-endpoint-checks",
          "antipattern.sql-in-http-handler"
        ],
        "includeRelated": true,
        "includeBody": true,
        "sectionTypes": ["guidance", "solution", "rules", "checks", "anti-patterns", "examples", "references"],
        "blockTypes": ["markdown", "list", "checklist", "code", "ppp-ref"]
      },
      "tasks": [
        {
          "slug": "task.expose-rust-axum-use-case-adapter",
          "validationIds": ["existing-use-case-boundary", "rust-cargo-check", "rust-format", "rust-tests", "boundary-review"]
        }
      ],
      "validations": ["validation.rust-api-endpoint-checks"],
      "dependencies": [
        {
          "ecosystem": "cargo",
          "packageName": "tower",
          "requirement": "^0.5",
          "resolvedVersion": "0.5.2",
          "scope": "dev-dependencies",
          "features": ["util"],
          "defaultFeatures": true,
          "optional": false,
          "dev": true,
          "build": false,
          "workspace": {
            "inherited": false,
            "member": true,
            "root": false,
            "packagePath": "crates/api"
          },
          "registry": "crates-io",
          "source": {
            "manifestPath": "crates/api/Cargo.toml",
            "lockfilePath": "Cargo.lock",
            "packageManager": "cargo",
            "packageManagerVersion": "1.84.0",
            "provenance": "Used by HTTP handler tests for service extension helpers."
          }
        }
      ]
    },
    {
      "id": "layered-ddd-context",
      "name": "Layered DDD application and domain context",
      "description": "Application/domain/persistence changes should preserve explicit boundaries and layered DDD direction.",
      "paths": [
        "crates/domain/src/**/*.rs",
        "crates/application/src/**/*.rs",
        "crates/infrastructure/src/**/*.rs"
      ],
      "tags": [
        { "tagId": "tag.layer", "value": "domain" }
      ],
      "ppp": {
        "requiredSlugs": [
          "principle.explicit-boundaries",
          "architecture.layered-ddd-backend"
        ],
        "includeRelated": true,
        "includeBody": true,
        "sectionTypes": ["guidance", "rules", "constraints", "checks", "references"],
        "blockTypes": ["markdown", "list", "checklist", "ppp-ref"]
      },
      "dependencies": [
        {
          "ecosystem": "cargo",
          "packageName": "async-trait",
          "requirement": "^0.1",
          "resolvedVersion": "0.1.83",
          "scope": "dependencies",
          "features": [],
          "defaultFeatures": true,
          "optional": false,
          "dev": false,
          "build": false,
          "workspace": {
            "inherited": true,
            "member": true,
            "root": true,
            "packagePath": "crates/application"
          },
          "registry": "crates-io",
          "source": {
            "manifestPath": "Cargo.toml",
            "lockfilePath": "Cargo.lock",
            "packageManager": "cargo",
            "packageManagerVersion": "1.84.0",
            "provenance": "Supports application-layer repository/use-case trait boundaries."
          }
        }
      ]
    }
  ]
}
