{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ppp-library.local/schemas/item.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "name", "slug", "status", "summary", "tags", "dependencies", "body"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["principle", "architecture", "pattern", "stack", "recipe", "validation", "antipattern"] },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "reviewed", "stable", "deprecated"] },
    "summary": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "$ref": "#/$defs/itemTag" }
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency" }
    },
    "supports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "implements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agent": { "$ref": "#/$defs/agent" },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/section" }
        }
      }
    }
  },
  "$defs": {
    "itemTag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tagId"],
      "properties": {
        "tagId": { "type": "string", "minLength": 1 },
        "value": true
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "enum": ["cargo", "npm", "pip", "go", "maven", "docker", "other"] },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rules": { "$ref": "#/$defs/stringList" },
        "constraints": { "$ref": "#/$defs/stringList" },
        "checks": { "$ref": "#/$defs/stringList" },
        "promptFragments": { "$ref": "#/$defs/stringList" },
        "applicability": { "$ref": "#/$defs/stringList" },
        "antiPatterns": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title", "blocks"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "problem",
            "guidance",
            "solution",
            "rules",
            "constraints",
            "examples",
            "checks",
            "anti-patterns",
            "references",
            "notes"
          ]
        },
        "title": { "type": "string" },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/block" }
        }
      }
    },
    "block": {
      "oneOf": [
        { "$ref": "#/$defs/markdownBlock" },
        { "$ref": "#/$defs/listBlock" },
        { "$ref": "#/$defs/checklistBlock" },
        { "$ref": "#/$defs/codeBlock" },
        { "$ref": "#/$defs/fileRefBlock" },
        { "$ref": "#/$defs/pppRefBlock" }
      ]
    },
    "markdownBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "markdown"],
      "properties": {
        "type": { "const": "markdown" },
        "markdown": { "type": "string" }
      }
    },
    "listBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "list" },
        "items": { "type": "array", "items": { "type": "string" } },
        "ordered": { "type": "boolean" }
      }
    },
    "checklistBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "checklist" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/checklistItem" }
        }
      }
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "checked": { "type": "boolean" },
        "required": { "type": "boolean" }
      }
    },
    "codeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "language", "code"],
      "properties": {
        "type": { "const": "code" },
        "language": { "type": "string", "minLength": 1 },
        "code": { "type": "string" },
        "filename": { "type": "string" }
      }
    },
    "fileRefBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": { "const": "file-ref" },
        "path": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "glob": { "type": "boolean" },
        "purpose": { "type": "string" }
      }
    },
    "pppRefBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slug"],
      "properties": {
        "type": { "const": "ppp-ref" },
        "slug": { "type": "string", "minLength": 1 },
        "note": { "type": "string" },
        "required": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  }
}
