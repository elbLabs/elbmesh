{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ppp-library.local/schemas/tag.schema.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/label" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "valueType", "options"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/label" },
        "valueType": { "const": "select" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "valueType"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/label" },
        "valueType": { "enum": ["text", "number", "boolean", "json"] }
      }
    }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^tag\\.[a-z0-9][a-z0-9.-]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    }
  }
}
